{
  "manifest_version": 3,
  "name": "Bounds Privacy Scanner",
  "short_name": "Bounds",
  "version": "0.2.0",
  "description": "Alerts you before uploading a PDF. Scans for names, IBANs, SSNs and more. Runs entirely in your browser — nothing is sent anywhere.",
  "permissions": [],
  "host_permissions": ["<all_urls>"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_end",
      "all_frames": true,
      "match_about_blank": true
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Bounds Privacy Scanner"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
